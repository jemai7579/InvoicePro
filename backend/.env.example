# ─────────────────────────────────────────────────────────────
#  El Fatoora — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# PostgreSQL connection string
# Local example: postgresql://elfatoora:yourpassword@localhost:5432/elfatooradb
# Docker example: postgresql://elfatoora:yourpassword@postgres:5432/elfatooradb
DATABASE_URL="postgresql://elfatoora:CHANGE_ME@localhost:5432/elfatooradb"

# JWT signing secret — use a long random string (min 32 characters)
# Generate one with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_use_a_long_random_secret_here"

# Server port (default: 5005)
PORT=5005

# Node environment: development | production
NODE_ENV=development
APP_ENV=development
E_INVOICE_MODE=mock

# Frontend URL for CORS whitelist
# Development: http://localhost:5173
# Production: http://your-server-ip or https://your-domain.com
FRONTEND_URL="http://localhost:5173"

# ── Optional: TTN (Tunisie TradeNet) ──────────────────────────
# Leave empty in development mock mode only. Production requires official TTN values.
TTN_BASE_URL=
TTN_AUTH_ENDPOINT=
TTN_SUBMIT_INVOICE_ENDPOINT=
TTN_STATUS_ENDPOINT=
TTN_DOWNLOAD_PROOF_ENDPOINT=
TTN_API_KEY=
TTN_CLIENT_ID=
TTN_CLIENT_SECRET=
TTN_USERNAME=
TTN_PASSWORD=

# ── Optional: Electronic signature provider ───────────────────
SIGNATURE_PROVIDER=mock
SIGNATURE_CERT_PATH=
SIGNATURE_CERT_PASSWORD=
SIGNATURE_CERT_ALIAS=
SIGNATURE_HSM_URL=
SIGNATURE_HSM_TOKEN=

# ── Optional: TEIF validation ─────────────────────────────────
TEIF_SCHEMA_VERSION=
TEIF_XSD_PATH=

# ── Optional: AI Assistant (Google Gemini) ────────────────────
# Leave empty to disable the AI chat feature gracefully.
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional: Email (SMTP) ────────────────────────────────────
# Leave empty to use Ethereal test accounts in development.
# For production, use SendGrid, Mailgun, or your own SMTP server.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
