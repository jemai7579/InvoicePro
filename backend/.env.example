# InvoicePro backend environment example
# Copy to .env and replace placeholders. Do not commit real secrets.

NODE_ENV=development
APP_ENV=development
E_INVOICE_MODE=mock

PORT=5005
DATABASE_URL="postgresql://elfatoora:secretpassword@localhost:5440/elfatooradb?schema=public"
JWT_SECRET="development_only_replace_with_a_random_secret_of_at_least_48_chars"
JWT_EXPIRES_IN="12h"
FRONTEND_URL="http://localhost:5173"

AUTH_FAILED_LOGIN_MAX=10
AUTH_FAILED_LOGIN_WINDOW_MINUTES=15
REGISTER_RATE_LIMIT_MAX=20
REGISTER_RATE_LIMIT_WINDOW_MINUTES=60
AI_MONTHLY_TOKEN_LIMIT=250000
# Reserved ceiling if an emergency global guard is enabled in future; normal API routes are not IP-throttled.
GENERAL_RATE_LIMIT_MAX=5000
GENERAL_RATE_LIMIT_WINDOW_MS=900000

GEMINI_API_KEY=""

TTN_API_URL=""
TTN_BASE_URL=""
TTN_AUTH_MODE=""
TTN_AUTH_ENDPOINT=""
TTN_SUBMIT_INVOICE_ENDPOINT=""
TTN_STATUS_ENDPOINT=""
TTN_PROOF_ENDPOINT=""
TTN_API_KEY=""
TTN_CLIENT_ID=""
TTN_CLIENT_SECRET=""
TTN_USERNAME=""
TTN_PASSWORD=""

TEIF_XSD_PATH=""
TEIF_SCHEMA_VERSION=""
STORAGE_PATH="uploads"

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

ENCRYPTION_KEY=""
SIGNATURE_PROVIDER=""
SIGNATURE_MODE=""
SIGNATURE_PROVIDER_NAME=""
SIGNATURE_API_KEY=""
SIGNATURE_KEY_PATH=""
SIGNATURE_HSM_URL=""
SIGNATURE_HSM_TOKEN=""
SIGNATURE_CERT_PATH=""
SIGNATURE_CERT_PASSWORD=""
SIGNATURE_CERT_ALIAS=""
BILLING_PROVIDER=""
BILLING_API_KEY=""
BILLING_WEBHOOK_SECRET=""
AI_PROVIDER=""
AI_API_KEY=""
GA4_MEASUREMENT_ID=""
GTM_CONTAINER_ID=""
GOOGLE_SEARCH_CONSOLE_SITE_URL=""
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=""
META_PIXEL_ID=""
