generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String             @id @default(uuid())
  email               String             @unique
  firstName           String?
  lastName            String?
  password            String
  name                String
  matriculeFiscal     String
  registreCommerce    String?
  address             String
  city                String?
  zipCode             String?
  country             String?            @default("Tunisie")
  phone               String?
  rib                 String?
  logo                String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  certificatePassword String?
  certificatePath     String?
  clients             Client[]
  devis               Devis[]
  invoices            Invoice[]
  products            Product[]
  notifications       Notification[]
  invoiceRequests     InvoiceRequest[]
  subscription        Subscription?
  settingsHistory     SettingsHistory[]
  documentSequences   DocumentSequence[]
}

model Admin {
  id        String        @id @default(uuid())
  email     String        @unique
  password  String
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  logs      ActivityLog[]
}

model Subscription {
  id        String    @id @default(uuid())
  companyId String    @unique
  plan      String    @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  status    String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate DateTime  @default(now())
  endDate   DateTime?
  company   Company   @relation(fields: [companyId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
}

model SystemSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?
}

model Client {
  id              String           @id @default(uuid())
  companyId       String
  number          String?
  name            String
  email           String?
  matriculeFiscal String?
  address         String?
  city            String?
  zipCode         String?
  country         String?          @default("Tunisie")
  phone           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id])
  devis           Devis[]
  invoices        Invoice[]
  invoiceRequests InvoiceRequest[]

  @@unique([companyId, number])
}

model Product {
  id           String        @id @default(uuid())
  companyId    String
  code         String?
  category     String?
  name         String
  description  String?
  priceHT      Float
  tvaRate      Float         @default(19)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id])
  devisLines   DevisLine[]
  invoiceLines InvoiceLine[]
}

model Devis {
  id             String      @id @default(uuid())
  companyId      String
  number         String?
  clientId       String
  status         DevisStatus @default(PENDING)
  note           String?
  totalHT        Float       @default(0)
  totalTVA       Float       @default(0)
  totalTTC       Float       @default(0)
  stampDuty      Float       @default(1.0)
  withholdingTax Float       @default(0)
  netToPay       Float       @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  client         Client      @relation(fields: [clientId], references: [id])
  company        Company     @relation(fields: [companyId], references: [id])
  lines          DevisLine[]
  invoice        Invoice?

  @@unique([companyId, number])
}

model DevisLine {
  id          String   @id @default(uuid())
  devisId     String
  productId   String?
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  tvaRate     Float    @default(19)
  totalHT     Float
  devis       Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Invoice {
  id             String        @id @default(uuid())
  devisId        String?       @unique
  companyId      String
  number         String?
  clientId       String
  status         InvoiceStatus @default(DRAFT)
  ttnId          String?
  ttnStatus      String?
  totalHT        Float         @default(0)
  totalTVA       Float         @default(0)
  totalTTC       Float         @default(0)
  stampDuty      Float         @default(1.0)
  withholdingTax Float         @default(0)
  netToPay       Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  client         Client        @relation(fields: [clientId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id])
  devis          Devis?        @relation(fields: [devisId], references: [id])
  lines          InvoiceLine[]

  @@unique([companyId, number])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  tvaRate     Float    @default(19)
  totalHT     Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model InvoiceRequest {
  id        String               @id @default(uuid())
  companyId String
  clientId  String
  status    InvoiceRequestStatus @default(PENDING)
  note      String?
  data      Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  company   Company              @relation(fields: [companyId], references: [id])
  client    Client               @relation(fields: [clientId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

enum DevisStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  VALIDATED
  TEIF_GENERATED
  SIGNED
  SENT_TO_TTN
  PENDING_TTN
  ACCEPTED_TTN
  REJECTED_TTN
  CANCELLED
  PENDING_VALIDATION
  PAID
  REJECTED
}

enum InvoiceRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model DocumentSequence {
  id           String               @id @default(uuid())
  companyId    String
  entityType   DocumentSequenceType
  year         Int
  currentValue Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, year])
}

enum DocumentSequenceType {
  INVOICE
  DEVIS
  PROJECT
  CLIENT
}

model SettingsHistory {
  id        String   @id @default(uuid())
  companyId String
  field     String // e.g., "name", "address"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}
