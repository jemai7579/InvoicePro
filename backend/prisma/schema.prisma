generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String    @id @default(uuid())
  email               String    @unique
  firstName           String?
  lastName            String?
  password            String
  name                String
  matriculeFiscal     String
  registreCommerce    String?
  address             String
  city                String?
  zipCode             String?
  country             String?   @default("Tunisie")
  phone               String?
  rib                 String?
  logo                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  certificatePassword String?
  certificatePath     String?
  eHouwiyaStatus      String    @default("NOT_STARTED")
  eHouwiyaIdentifier  String?
  eHouwiyaVerifiedAt  DateTime?
  clients             Client[]
  devis               Devis[]
  invoices            Invoice[]
  products            Product[]
  notifications       Notification[]
  invoiceRequests     InvoiceRequest[]
  subscription        Subscription?
  settingsHistory     SettingsHistory[]
  documentSequences   DocumentSequence[]
  auditTrails         UserActivityLog[]
  offers              Offer[]
  payments            Payment[]
  onboardingRequests  OnboardingRequest[]
  sentPlatformInvitations     PlatformInvitation[] @relation("PlatformInvitationSender")
  receivedPlatformInvitations PlatformInvitation[] @relation("PlatformInvitationRecipient")
  partnerConnectionsA         PartnerConnection[]  @relation("PartnerConnectionA")
  partnerConnectionsB         PartnerConnection[]  @relation("PartnerConnectionB")
  sentPartnerMessages         PartnerMessage[]     @relation("PartnerMessageSender")
  receivedPartnerMessages     PartnerMessage[]     @relation("PartnerMessageRecipient")
  adminProfile                AdminCompanyProfile?
  adminNotes                  AdminCompanyNote[]
  adminSupportTickets         AdminSupportTicket[]
  adminSystemErrors           AdminSystemError[]
  adminPlatformPayments       AdminPlatformPayment[]
  adminDossierStatusHistory   AdminDossierStatusHistory[]
  adminCompanyStatusHistory   AdminCompanyStatusHistory[]
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
  adminNotes AdminCompanyNote[]
  supportReplies AdminSupportReply[]
  dossierStatusHistory AdminDossierStatusHistory[]
  companyStatusHistory AdminCompanyStatusHistory[]
}

model Subscription {
  id        String   @id @default(uuid())
  companyId String   @unique
  plan      String   @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  status    String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate DateTime @default(now())
  endDate   DateTime?
  company   Company  @relation(fields: [companyId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
}

model IntegrationSecret {
  id            String   @id @default(uuid())
  key           String   @unique
  encryptedValue String?
  publicValue   String?
  valueType     String   @default("secret")
  lastUpdatedBy String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([key])
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventType  String
  path       String
  referrer   String?
  userAgent  String?
  deviceType String?
  country    String?
  city       String?
  companyId  String?
  sessionId  String
  visitorId  String
  ipHash     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([path, createdAt])
  @@index([companyId, createdAt])
  @@index([visitorId, createdAt])
}

model AdminCompanyProfile {
  id            String   @id @default(uuid())
  companyId     String   @unique
  status        String   @default("active")
  dossierStatus String   @default("incomplete")
  requestedDocuments Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([dossierStatus])
}

model AdminCompanyNote {
  id          String   @id @default(uuid())
  targetType  String   @default("company")
  targetId    String
  companyId   String?
  adminId     String?
  authorName  String
  content     String
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  admin       Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([companyId, createdAt])
}

model AdminSupportTicket {
  id          String   @id @default(uuid())
  companyId   String?
  userLabel   String   @default("Company owner")
  subject     String
  message     String   @default("")
  category    String   @default("general")
  priority    String   @default("normal")
  status      String   @default("open")
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  replies     AdminSupportReply[]

  @@index([companyId, status])
  @@index([status, createdAt])
}

model AdminSupportReply {
  id        String   @id @default(uuid())
  ticketId  String
  adminId   String?
  authorName String
  message   String
  createdAt DateTime @default(now())
  ticket    AdminSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model AdminSystemError {
  id        String   @id @default(uuid())
  type      String
  companyId String?
  severity  String
  message   String
  status    String   @default("new")
  note      String?
  route     String?
  stack     String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, severity])
  @@index([companyId, createdAt])
}

model AdminPlatformPayment {
  id              String   @id @default(uuid())
  companyId       String
  plan            String
  amount          Float
  currency        String   @default("TND")
  status          String
  paymentDate     DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  nextBillingDate DateTime?
  method          String?
  providerReference String?
  createdByAdminId String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([status, createdAt])
}

model AdminDossierStatusHistory {
  id        String   @id @default(uuid())
  companyId String
  adminId   String?
  oldStatus String?
  newStatus String
  note      String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model AdminCompanyStatusHistory {
  id         String   @id @default(uuid())
  companyId  String
  adminId    String?
  actionType String   @default("status_change")
  oldValue   String?
  newValue   String
  note       String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([companyId, actionType, createdAt])
}

model SystemSetting {
  id          String @id @default(uuid())
  key         String @unique
  value       String
  description String?
}

model Client {
  id              String    @id @default(uuid())
  companyId       String
  number          String?
  name            String
  email           String?
  matriculeFiscal String?
  address         String?
  city            String?
  rne             String?
  notes           String?
  zipCode         String?
  country         String?   @default("Tunisie")
  phone           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id])
  devis           Devis[]
  invoices        Invoice[]
  offers          Offer[]
  invoiceRequests InvoiceRequest[]

  @@unique([companyId, number])
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  code        String?
  category    String?
  name        String
  description String?
  priceHT     Float
  tvaRate     Float    @default(19)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  devisLines   DevisLine[]
  invoiceLines InvoiceLine[]
}

model Devis {
  id             String      @id @default(uuid())
  companyId      String
  number         String?
  clientId       String
  status         DevisStatus @default(PENDING)
  note           String?
  totalHT        Float       @default(0)
  totalTVA       Float       @default(0)
  totalTTC       Float       @default(0)
  stampDuty      Float       @default(1.0)
  withholdingTax Float       @default(0)
  netToPay       Float       @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  client         Client      @relation(fields: [clientId], references: [id])
  company        Company     @relation(fields: [companyId], references: [id])
  lines          DevisLine[]
  invoice        Invoice?

  @@unique([companyId, number])
}

model DevisLine {
  id          String   @id @default(uuid())
  devisId      String
  productId    String?
  description  String
  quantity     Float    @default(1)
  unitPrice    Float
  tvaRate      Float    @default(19)
  totalHT      Float
  devis        Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Invoice {
  id             String        @id @default(uuid())
  devisId        String?       @unique
  companyId      String
  number         String?
  clientId       String
  status         InvoiceStatus @default(DRAFT)
  legalStatus    String        @default("draft")
  paymentStatus  String        @default("unpaid")
  ttnId          String?
  ttnStatus      String?
  ttnReference   String?
  ttnProofPath   String?
  teifXmlPath    String?
  teifXmlHash    String?
  teifGeneratedAt DateTime?
  teifVersion    String?
  signedXmlPath  String?
  signatureStatus String?
  signatureTimestamp DateTime?
  signedByUserId String?
  certificateIdentifier String?
  totalHT        Float         @default(0)
  totalTVA       Float         @default(0)
  totalTTC       Float         @default(0)
  stampDuty      Float         @default(1.0)
  withholdingTax Float         @default(0)
  netToPay       Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  client         Client        @relation(fields: [clientId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id])
  devis          Devis?        @relation(fields: [devisId], references: [id])
  lines          InvoiceLine[]
  payments       Payment[]

  @@unique([companyId, number])
}

model Offer {
  id                     String         @id @default(uuid())
  companyId              String
  clientId               String?
  invoiceRequestId       String?
  number                 String?
  title                  String
  description            String?
  estimatedAmount        Float          @default(0)
  deliveryDelay          String?
  validUntil             DateTime?
  terms                  String?
  purchaseOrderReference String?
  purchaseOrderFile      String?
  status                 String         @default("DRAFT")
  publicToken            String?        @unique
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  company                Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client                 Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  comments               OfferComment[]

  @@unique([companyId, number])
}

model OfferComment {
  id        String   @id @default(uuid())
  offerId   String
  actorType String   @default("USER")
  message   String
  createdAt DateTime @default(now())
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(uuid())
  companyId   String
  invoiceId   String
  amount      Float
  paymentDate DateTime @default(now())
  method      String   @default("CASH")
  status      String   @default("PAID")
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId    String
  productId    String?
  description  String
  quantity     Float    @default(1)
  unitPrice    Float
  tvaRate      Float    @default(19)
  totalHT      Float
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model InvoiceRequest {
  id        String              @id @default(uuid())
  companyId String
  clientId  String
  status    InvoiceRequestStatus @default(PENDING)
  note      String?
  data      Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  company   Company             @relation(fields: [companyId], references: [id])
  client    Client              @relation(fields: [clientId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

enum DevisStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  VALIDATED
  TEIF_GENERATED
  SIGNED
  SENT_TO_TTN
  PENDING_TTN
  ACCEPTED_TTN
  REJECTED_TTN
  CANCELLED
  PENDING_VALIDATION
  PAID
  REJECTED
}

enum InvoiceRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model DocumentSequence {
  id          String               @id @default(uuid())
  companyId    String
  entityType   DocumentSequenceType
  year         Int
  currentValue Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, year])
}

enum DocumentSequenceType {
  INVOICE
  DEVIS
  OFFER
  PROJECT
  CLIENT
}

model SettingsHistory {
  id        String   @id @default(uuid())
  companyId String
  field     String   // e.g., "name", "address"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model UserActivityLog {
  id         String   @id @default(uuid())
  companyId  String
  actorId    String?
  actorType  String
  actionType String
  objectType String
  objectId   String
  message    String
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  errorMessage String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, objectType, objectId])
}

model SignatureProviderOption {
  id                String   @id @default(uuid())
  name              String
  targetUsers       String
  costDescription   String?
  difficulty        String   @default("UNKNOWN")
  setupInstructions String
  status            String   @default("NEEDS_VERIFICATION")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OnboardingRequest {
  id          String   @id @default(uuid())
  companyId   String?
  name        String
  companyName String
  email       String
  phone       String?
  needType    String
  message     String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
}

model PlatformInvitation {
  id                 String   @id @default(uuid())
  senderCompanyId    String
  recipientCompanyId String?
  recipientEmail     String
  status             String   @default("PENDING")
  message            String?
  respondedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  senderCompany      Company  @relation("PlatformInvitationSender", fields: [senderCompanyId], references: [id], onDelete: Cascade)
  recipientCompany   Company? @relation("PlatformInvitationRecipient", fields: [recipientCompanyId], references: [id], onDelete: SetNull)

  @@index([senderCompanyId, status])
  @@index([recipientCompanyId, status])
  @@index([recipientEmail, status])
}

model PartnerConnection {
  id         String   @id @default(uuid())
  companyAId String
  companyBId String
  status     String   @default("ACCEPTED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  companyA   Company  @relation("PartnerConnectionA", fields: [companyAId], references: [id], onDelete: Cascade)
  companyB   Company  @relation("PartnerConnectionB", fields: [companyBId], references: [id], onDelete: Cascade)

  @@unique([companyAId, companyBId])
  @@index([companyAId, status])
  @@index([companyBId, status])
}

model PartnerMessage {
  id                 String   @id @default(uuid())
  senderCompanyId    String
  recipientCompanyId String
  body               String
  metadata           Json?
  readAt             DateTime?
  createdAt          DateTime @default(now())
  senderCompany      Company  @relation("PartnerMessageSender", fields: [senderCompanyId], references: [id], onDelete: Cascade)
  recipientCompany   Company  @relation("PartnerMessageRecipient", fields: [recipientCompanyId], references: [id], onDelete: Cascade)

  @@index([senderCompanyId, recipientCompanyId, createdAt])
  @@index([recipientCompanyId, createdAt])
}
