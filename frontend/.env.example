# ─────────────────────────────────────────────────────────────
#  El Fatoora — Frontend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Development: http://localhost:5005/api
# Production: http://your-server-ip:5005/api or https://api.your-domain.com/api
VITE_API_URL=http://localhost:5005/api

# App version shown in UI (optional)
VITE_APP_VERSION=1.2.0
